# Copy this file to ~/.dbt/profiles.yml and fill in your Supabase credentials.
# NEVER commit the actual profiles.yml — it contains secrets.

garmin_health:
  outputs:
    dev:
      type: postgres
      host: <your-supabase-host>.supabase.co
      port: 5432
      user: postgres
      password: <your-supabase-db-password>
      dbname: postgres
      schema: dbt_dev
      threads: 1
      keepalives_idle: 0
      connect_timeout: 10
      search_path: dbt_dev

    prod:
      type: postgres
      host: <your-supabase-host>.supabase.co
      port: 5432
      user: postgres
      password: <your-supabase-db-password>
      dbname: postgres
      schema: dbt_prod
      threads: 1
      keepalives_idle: 0
      connect_timeout: 10
      search_path: dbt_prod

  target: dev
