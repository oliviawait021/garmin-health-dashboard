# ── Garmin Connect ────────────────────────────────────────────
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your-garmin-password

# Path where garminconnect caches session tokens (avoids re-auth each run)
GARMIN_TOKEN_PATH=/tmp/garmin_tokens

# ── Supabase ──────────────────────────────────────────────────
# Direct PostgreSQL connection string (Settings → Database → Connection string)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# REST / anon key (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── dbt (GitHub Actions only — written into profiles.yml at CI time) ──
DBT_HOST=db.<project-ref>.supabase.co
DBT_PASSWORD=your-supabase-db-password
